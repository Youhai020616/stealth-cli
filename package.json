{
  "name": "stealth-cli",
  "version": "0.7.0",
  "description": "Anti-detection browser CLI powered by Camoufox. Browse, search, scrape, and crawl the web with C++ level fingerprint spoofing.",
  "type": "module",
  "bin": {
    "stealth": "bin/stealth.js"
  },
  "main": "src/index.js",
  "files": [
    "bin/",
    "src/",
    "skills/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/stealth.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "postinstall": "npx camoufox-js fetch || true",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "browser",
    "cli",
    "anti-detection",
    "camoufox",
    "stealth",
    "scraping",
    "automation",
    "headless",
    "fingerprint",
    "web-scraping",
    "anti-bot",
    "cloudflare",
    "playwright",
    "firefox"
  ],
  "author": "xyh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Youhai020616/stealth-cli.git"
  },
  "homepage": "https://github.com/Youhai020616/stealth-cli#readme",
  "bugs": {
    "url": "https://github.com/Youhai020616/stealth-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "camoufox-js": "^0.9.2",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "ora": "^8.0.0",
    "playwright-core": "1.59.1"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "generative-bayesian-network": "2.1.86"
  }
}
