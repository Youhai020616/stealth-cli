{
  "name": "stealth-cli",
  "version": "0.5.0",
  "description": "Anti-detection browser CLI powered by Camoufox",
  "type": "module",
  "bin": {
    "stealth": "./bin/stealth.js"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node bin/stealth.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "postinstall": "npx camoufox-js fetch || true"
  },
  "keywords": [
    "browser",
    "cli",
    "anti-detection",
    "camoufox",
    "stealth",
    "scraping",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "camoufox-js": "^0.9.2",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "ora": "^8.0.0",
    "playwright-core": "^1.58.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
